---
import { t, localePath } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
---

<footer style="background: var(--bg-base); border-top: 1px solid var(--border);">
  <!-- Glow divider -->
  <div class="comic-divider"></div>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div class="flex flex-col items-center md:items-start">
        <div class="flex items-center space-x-3 mb-4">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg"
               style="background: var(--accent); border: 1px solid var(--border-accent); box-shadow: var(--glow-sm);">
            <span class="text-lg font-bold text-white">JG</span>
          </div>
          <span class="text-base font-semibold" style="color: var(--text-primary);">
            Juan S. Guerrero Britos
          </span>
        </div>
        <p class="text-sm text-center md:text-left max-w-xs" style="color: var(--text-muted); font-family: var(--font-body);">
          {t('footer.description', lang)}
        </p>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-col items-center md:items-start">
        <h3 class="mb-4 font-semibold" style="color: var(--text-primary); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.8px;">{t('footer.quickLinks', lang)}</h3>
        <nav class="flex flex-col space-y-2">
          <a href={localePath('/', lang)} class="footer-link text-sm transition-all duration-200" style="color: var(--text-muted);">
            <i class="fas fa-chevron-right mr-1.5 text-xs" style="color: var(--accent-light);"></i> {t('nav.home', lang)}
          </a>
          <a href={localePath('/experience', lang)} class="footer-link text-sm transition-all duration-200" style="color: var(--text-muted);">
            <i class="fas fa-chevron-right mr-1.5 text-xs" style="color: var(--accent-light);"></i> {t('nav.experience', lang)}
          </a>
          <a href={localePath('/projects', lang)} class="footer-link text-sm transition-all duration-200" style="color: var(--text-muted);">
            <i class="fas fa-chevron-right mr-1.5 text-xs" style="color: var(--accent-light);"></i> {t('nav.projects', lang)}
          </a>
          <a href={localePath('/contact', lang)} class="footer-link text-sm transition-all duration-200" style="color: var(--text-muted);">
            <i class="fas fa-chevron-right mr-1.5 text-xs" style="color: var(--accent-light);"></i> {t('nav.contact', lang)}
          </a>
        </nav>
      </div>

      <!-- Social -->
      <div class="flex flex-col items-center md:items-start">
        <h3 class="mb-4 font-semibold" style="color: var(--text-primary); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.8px;">{t('footer.connect', lang)}</h3>
        <div class="flex space-x-3">
          <a href="https://github.com/gjohnn" target="_blank" rel="noopener noreferrer"
             class="social-btn p-2.5 rounded-lg transition-all duration-200"
             style="background: var(--bg-elevated); color: var(--text-primary); border: 1px solid var(--border);"
             aria-label="GitHub">
            <i class="fab fa-github text-lg"></i>
          </a>
          <a href="https://linkedin.com/in/juan-guerrero" target="_blank" rel="noopener noreferrer"
             class="social-btn p-2.5 rounded-lg transition-all duration-200"
             style="background: var(--bg-elevated); color: var(--accent-light); border: 1px solid var(--border);"
             aria-label="LinkedIn">
            <i class="fab fa-linkedin text-lg"></i>
          </a>
          <a href="mailto:contact@juanguerrero.dev"
             class="social-btn p-2.5 rounded-lg transition-all duration-200"
             style="background: var(--bg-elevated); color: var(--accent-light); border: 1px solid var(--border);"
             aria-label="Email">
            <i class="fas fa-envelope text-lg"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6" style="border-top: 1px solid var(--border);">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center space-x-2 text-center md:text-left">
          <p class="text-sm" style="color: var(--text-muted);">
            &copy; 2025
            <span style="color: var(--accent-light); font-weight: 600;">Juan Sebastián Guerrero Britos</span>.
            {t('footer.allRights', lang)}
          </p>
        </div>
        <div class="flex items-center space-x-2 text-center md:text-right">
          <span class="text-xs" style="color: var(--text-muted);">{t('footer.builtWith', lang)}</span>
          <div class="flex items-center space-x-2">
            <span class="text-xs font-medium" style="color: var(--accent-light);">Astro</span>
            <span style="color: var(--border);">+</span>
            <span class="text-xs font-medium" style="color: var(--accent-light);">Tailwind</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--accent-light) !important;
    transform: translateX(3px);
  }
  .social-btn:hover {
    border-color: var(--border-accent);
    box-shadow: var(--glow-sm);
    transform: translateY(-2px);
    color: var(--white) !important;
  }
</style>
