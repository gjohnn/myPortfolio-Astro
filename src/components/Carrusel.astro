---
import { Icon } from 'astro-iconify';
import { skillsCarousels } from '../data/skills';
import { defaultLang } from '../i18n/ui';

const skills = skillsCarousels[defaultLang];
---

<div class="space-y-8">
  {skills.map((section) => {
    return (
      <div class="card p-4 sm:p-6 overflow-hidden" style="border-top: 2px solid var(--accent);">
        <!-- Section Title -->
        <h3 class="text-base sm:text-lg mb-4 flex items-center gap-2 font-semibold"
            style="color: var(--accent-light);">
          <span class="inline-block w-2 h-2 rounded-full" style="background: var(--accent); box-shadow: var(--glow-sm);"></span>
          {section.title}
        </h3>

        <!-- Marquee Container -->
        <div class="marquee-wrapper">
          <div class="marquee-content" style="gap: 0.75rem;">
            {[...Array(6)].map(() => (
              section.skills.map((skill) => (
                <div class="flex items-center gap-2 px-4 py-2 rounded-lg flex-shrink-0"
                     style="background: var(--accent-subtle); border: 1px solid var(--border); color: var(--text-secondary);">
                  {skill.icon.startsWith('http') ? (
                    <img src={skill.icon} alt={skill.name} class="w-5 h-5" />
                  ) : (
                    <Icon name={skill.icon} class="w-5 h-5" style="color: var(--accent-light);" />
                  )}
                  <span class="text-sm font-medium whitespace-nowrap" style="color: var(--text-secondary);">
                    {skill.name}
                  </span>
                </div>
              ))
            ))}
          </div>
        </div>
      </div>
    );
  })}
</div>
