---
import { educationData } from '../../data/my-education';
import { t } from '../../i18n/utils';
import { defaultLang, type Lang } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const data = educationData[lang] ?? educationData[defaultLang];

const typeIcons: Record<string, string> = {
  degree: 'fas fa-graduation-cap',
  certification: 'fas fa-certificate',
  school: 'fas fa-school',
};
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {data.map((edu, index) => (
    <article class="card p-5 sm:p-6 relative group animate-on-scroll edu-card"
             style="border-left: 2px solid var(--accent);"
             class:list={[`animation-delay-${index}`]}>

      {/* Status Badge */}
      {edu.status === 'current' && (
        <div class="absolute -top-2 -right-2 comic-badge flex items-center gap-1">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background: var(--accent-light);"></span>
            <span class="relative inline-flex rounded-full h-2 w-2" style="background: var(--accent-light);"></span>
          </span>
          {t('education.activeNow', lang)}
        </div>
      )}
      {edu.status === 'completed' && (
        <div class="absolute -top-2 -right-2 comic-badge flex items-center gap-1">
          <i class="fas fa-check text-xs"></i>
          {t('education.completed', lang)}
        </div>
      )}

      {/* Icon & Title */}
      <div class="flex items-start gap-3 mb-3">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
             style="background: var(--accent-subtle); border: 1px solid var(--border-accent); box-shadow: var(--glow-sm);">
          <i class={`${typeIcons[edu.type]}`} style="color: var(--accent-light);"></i>
        </div>
        <div class="flex-1">
          <h3 class="text-base sm:text-lg leading-tight font-semibold"
              style="color: var(--text-primary);">
            {edu.title}
          </h3>
          <p class="text-sm mt-1" style="color: var(--text-muted);">
            {edu.institution}
          </p>
        </div>
      </div>

      {/* Period */}
      <div class="flex items-center gap-2 mb-3">
        <i class="fas fa-calendar-alt text-xs" style="color: var(--accent-light);"></i>
        <span class="text-xs font-medium" style="color: var(--text-muted);">{edu.period}</span>
      </div>

      {/* Description */}
      {edu.description && (
        <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
          {edu.description}
        </p>
      )}
    </article>
  ))}
</div>

<style>
  .edu-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .edu-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--glow-md);
    border-color: var(--border-accent) !important;
  }
</style>
