<!-- Timeline -->
<div class="relative">
  <!-- Center Line (desktop) -->
  <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px -translate-x-1/2"
       style="background: linear-gradient(to bottom, transparent, var(--accent), var(--accent-light), var(--accent), transparent);"></div>

  <!-- Mobile Line -->
  <div class="md:hidden absolute left-6 top-0 bottom-0 w-px"
       style="background: linear-gradient(to bottom, var(--accent), var(--accent-light));"></div>

  {data.map((exp, index) => {
    const isEven = index % 2 === 0;

    return (
      <div class={`relative mb-8 md:mb-12 md:flex ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
        <!-- Timeline Dot -->
        <div class="absolute left-6 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full z-10 animate-glow-pulse"
             style={`background: var(--accent); border: 2px solid var(--bg-base); box-shadow: var(--glow-sm); top: 1.5rem;`}>
        </div>

        <!-- Spacer -->
        <div class="hidden md:block md:w-1/2"></div>

        <!-- Card -->
        <div class={`ml-14 md:ml-0 md:w-1/2 ${isEven ? 'md:pl-8' : 'md:pr-8'}`}>
          <article class="card p-5 sm:p-6 experience-card animate-on-scroll" style="border-top: 2px solid var(--accent);">
            <!-- Header -->
            <div class="flex items-start justify-between mb-3">
              <div class="flex-1">
                <h3 class="text-lg sm:text-xl font-semibold mb-1" style="color: var(--text-primary);">
                  {exp.role}
                </h3>
                <div class="flex items-center gap-2 mt-1">
                  {exp.companyUrl ? (
                    <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer"
                       class="text-sm hover:underline font-medium"
                       style="color: var(--accent-light);">
                      {exp.company} <i class="fas fa-external-link-alt text-xs"></i>
                    </a>
                  ) : (
                    <span class="text-sm font-medium" style="color: var(--accent-light);">{exp.company}</span>
                  )}
                </div>
                {exp.project && (
                  <div class="mt-1">
                    {exp.projectUrl ? (
                      <a href={exp.projectUrl} target="_blank" rel="noopener noreferrer"
                         class="text-xs hover:underline" style="color: var(--text-muted);">
                        {exp.project} <i class="fas fa-external-link-alt text-xs"></i>
                      </a>
                    ) : (
                      <span class="text-xs" style="color: var(--text-muted);">{exp.project}</span>
                    )}
                  </div>
                )}
              </div>
              <span class="text-xs px-3 py-1 rounded flex-shrink-0 ml-2 font-medium"
                    style="background: var(--accent-subtle); border: 1px solid var(--border-accent); color: var(--accent-light);">
                {exp.period}
              </span>
            </div>

            <!-- Technologies -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {exp.technologies.map(tech => (
                <span class="tech-badge text-xs">{tech}</span>
              ))}
            </div>

            <!-- Responsibilities (collapsible) -->
            <details class="exp-details">
              <summary class="cursor-pointer text-sm flex items-center gap-2 select-none font-medium"
                       style="color: var(--accent-light);">
                <i class="fas fa-chevron-right text-xs exp-chevron transition-transform"></i>
                {t('exp.responsibilities', lang)} ({exp.responsibilities.length})
              </summary>
              <div class="mt-3 space-y-2 pl-3" style="border-left: 2px solid var(--border-accent);">
                {exp.responsibilities.map(resp => (
                  <div class="flex items-start gap-2 text-sm">
                    <i class="fas fa-chevron-right text-xs mt-1 flex-shrink-0" style="color: var(--accent-light);"></i>
                    <span style="color: var(--text-secondary);">{resp}</span>
                  </div>
                ))}
              </div>
            </details>
          </article>
        </div>
      </div>
    );
  })}
</div>

<style>
  .exp-details[open] .exp-chevron {
    transform: rotate(90deg);
  }
  .experience-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .experience-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--glow-md);
    border-color: var(--border-accent) !important;
  }
</style>