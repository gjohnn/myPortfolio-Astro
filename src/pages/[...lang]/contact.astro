---
import MainLayout from "../../layouts/MainLayout.astro";
import { getLangFromUrl, t, localePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLangFromUrl(Astro.url) as Lang;
---

<MainLayout lang={lang}>
  <div class="relative max-w-5xl mx-auto">
    <!-- Page Header -->
    <section class="text-center mb-12 sm:mb-16 animate-on-scroll px-4">
      <h1 class="comic-title text-4xl mt-8 sm:text-5xl md:text-6xl mb-4" style="color: var(--text-primary);">
        {t('contact.title', lang)}
      </h1>
      <p class="text-base sm:text-lg max-w-3xl mx-auto leading-relaxed"
         style="color: var(--text-muted);">
        {t('contact.subtitle', lang)}
      </p>
      <div class="mt-4 w-20 h-px mx-auto" style="background: linear-gradient(90deg, transparent, var(--accent), var(--accent-light), transparent); box-shadow: 0 0 8px rgba(124,58,237,0.5);"></div>
    </section>

    <!-- Contact Methods -->
    <section class="max-w-4xl mx-auto animate-on-scroll px-4">
      <div class="grid md:grid-cols-2 gap-6 sm:gap-8 mb-12 sm:mb-16">
        <!-- Quick Contact -->
        <div class="card p-6 sm:p-8 animate-slide-in-up" style="border-top: 2px solid var(--accent);">
          <h2 class="text-xl sm:text-2xl mb-6 flex items-center font-semibold" style="color: var(--text-primary);">
            <i class="fas fa-paper-plane mr-3" style="color: var(--accent-light);"></i>
            {t('contact.quickContact', lang)}
          </h2>

          <div class="space-y-4">
            <!-- Email -->
            <a href="mailto:juansgb316@outlook.com"
               class="contact-item flex items-center gap-4 p-4 rounded-lg group transition-all duration-200"
               style="background: var(--bg-elevated); border: 1px solid var(--border);">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg flex items-center justify-center"
                   style="background: var(--accent); border: 1px solid var(--border-accent); box-shadow: var(--glow-sm);">
                <i class="fas fa-envelope text-white text-lg"></i>
              </div>
              <div>
                <div class="font-medium" style="color: var(--text-primary);">{t('contact.email', lang)}</div>
                <div class="text-sm" style="color: var(--text-muted);">juansgb316@outlook.com</div>
              </div>
            </a>

            <!-- Copy Email Button -->
            <button id="copyEmailBtn"
                    class="w-full p-3 rounded-lg transition-all duration-200 text-sm cursor-pointer font-medium"
                    style="background: var(--bg-elevated); border: 1px dashed var(--border-accent); color: var(--accent-light);"
                    data-copy-label={t('contact.copyEmail', lang)}
                    data-copied-label={t('contact.emailCopied', lang)}
                    data-failed-label={t('contact.copyFailed', lang)}>
              <i id="copyEmailIcon" class="fas fa-copy mr-2"></i>
              <span id="copyEmailText">{t('contact.copyEmail', lang)}</span>
            </button>

            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/in/juan-guerre3168" target="_blank" rel="noopener noreferrer"
               class="contact-item flex items-center gap-4 p-4 rounded-lg group transition-all duration-200"
               style="background: var(--bg-elevated); border: 1px solid var(--border);">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg flex items-center justify-center"
                   style="background: var(--accent); border: 1px solid var(--border-accent); box-shadow: var(--glow-sm);">
                <i class="fab fa-linkedin text-white text-lg"></i>
              </div>
              <div class="flex-1">
                <div class="font-medium" style="color: var(--text-primary);">{t('contact.linkedin', lang)}</div>
                <div class="text-sm" style="color: var(--text-muted);">{t('contact.linkedinDesc', lang)}</div>
              </div>
              <i class="fas fa-external-link-alt" style="color: var(--accent-light);"></i>
            </a>

            <!-- GitHub -->
            <a href="https://github.com/gjohnn" target="_blank" rel="noopener noreferrer"
               class="contact-item flex items-center gap-4 p-4 rounded-lg group transition-all duration-200"
               style="background: var(--bg-elevated); border: 1px solid var(--border);">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg flex items-center justify-center"
                   style="background: var(--bg-overlay); border: 1px solid var(--border); box-shadow: var(--glow-sm);">
                <i class="fab fa-github text-white text-lg"></i>
              </div>
              <div class="flex-1">
                <div class="font-medium" style="color: var(--text-primary);">{t('contact.github', lang)}</div>
                <div class="text-sm" style="color: var(--text-muted);">{t('contact.githubDesc', lang)}</div>
              </div>
              <i class="fas fa-external-link-alt" style="color: var(--text-muted);"></i>
            </a>
          </div>
        </div>

        <!-- Let's Discuss -->
        <div class="card p-6 sm:p-8 animate-slide-in-up" style="border-top: 2px solid var(--accent); animation-delay: 0.1s;">
          <h2 class="text-xl sm:text-2xl mb-6 flex items-center font-semibold" style="color: var(--text-primary);">
            <i class="fas fa-info-circle mr-3" style="color: var(--accent-light);"></i>
            {t('contact.letsDiscuss', lang)}
          </h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center mt-1"
                   style="background: var(--accent-subtle); border: 1px solid var(--border-accent); box-shadow: var(--glow-sm);">
                <i class="fas fa-handshake text-sm" style="color: var(--accent-light);"></i>
              </div>
              <div>
                <h3 class="font-semibold mb-1" style="color: var(--text-primary);">{t('contact.projectCollab', lang)}</h3>
                <p class="text-sm" style="color: var(--text-muted);">{t('contact.projectCollabDesc', lang)}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center mt-1"
                   style="background: var(--accent-subtle); border: 1px solid var(--border-accent); box-shadow: var(--glow-sm);">
                <i class="fas fa-briefcase text-sm" style="color: var(--accent-light);"></i>
              </div>
              <div>
                <h3 class="font-semibold mb-1" style="color: var(--text-primary);">{t('contact.jobOpportunities', lang)}</h3>
                <p class="text-sm" style="color: var(--text-muted);">{t('contact.jobOpportunitiesDesc', lang)}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center mt-1"
                   style="background: var(--accent-subtle); border: 1px solid var(--border-accent); box-shadow: var(--glow-sm);">
                <i class="fas fa-comments text-sm" style="color: var(--accent-light);"></i>
              </div>
              <div>
                <h3 class="font-semibold mb-1" style="color: var(--text-primary);">{t('contact.techDiscussion', lang)}</h3>
                <p class="text-sm" style="color: var(--text-muted);">{t('contact.techDiscussionDesc', lang)}</p>
              </div>
            </div>
          </div>

          <div class="mt-8 pt-4" style="border-top: 1px solid var(--border);">
            <p class="text-sm text-center" style="color: var(--text-muted);">
              <i class="fas fa-clock mr-2" style="color: var(--accent-light);"></i>
              {t('contact.responseTime', lang)}
            </p>
          </div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="flex justify-center animate-on-scroll">
        <div class="card p-6 sm:p-8 w-full max-w-2xl text-center" style="border-top: 2px solid var(--accent); box-shadow: var(--glow-md);">
          <div class="comic-action inline-block mb-3" style="font-size: 0.7rem;">{t('contact.letsGo', lang)}</div>
          <h2 class="comic-title text-xl sm:text-2xl mb-4" style="color: var(--text-primary);">
            {t('contact.readyToStart', lang)}
          </h2>
          <p class="mb-6" style="color: var(--text-muted);">
            {t('contact.readyDesc', lang)}
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="mailto:juansgb316@outlook.com" class="btn btn-primary group">
              <i class="fas fa-envelope mr-2"></i>
              {t('contact.sendEmail', lang)}
            </a>
            <a href="/JuanGuerreroCv_Public.pdf" download="Juan_Sebastián_Guerrero_Britos_CV.pdf"
               class="btn btn-secondary group">
              <i class="fas fa-download mr-2"></i>
              {t('cta.downloadResume', lang)}
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .contact-item:hover {
      border-color: var(--border-accent) !important;
      box-shadow: var(--glow-sm);
      transform: translateY(-1px);
    }
  </style>

  <script is:inline>
    (function () {
      const btn = document.getElementById('copyEmailBtn');
      if (!btn) return;

      const copyLabel = btn.getAttribute('data-copy-label');
      const copiedLabel = btn.getAttribute('data-copied-label');
      const failedLabel = btn.getAttribute('data-failed-label');

      btn.addEventListener('click', () => {
        const email = 'juansgb316@outlook.com';
        navigator.clipboard.writeText(email).then(() => {
          const text = document.getElementById('copyEmailText');
          const icon = document.getElementById('copyEmailIcon');
          
          text.textContent = copiedLabel;
          icon.className = 'fas fa-check mr-2';
          
          setTimeout(() => {
            text.textContent = copyLabel;
            icon.className = 'fas fa-copy mr-2';
          }, 3000);
        }).catch(err => {
          console.error('Failed to copy email: ', err);
          const text = document.getElementById('copyEmailText');
          text.textContent = failedLabel;
          setTimeout(() => {
            text.textContent = copyLabel;
          }, 2000);
        });
      });
    })();
  </script>
</MainLayout>
